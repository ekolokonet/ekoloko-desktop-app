{
  "name": "ekoloko-rewritten",
  "version": "1.0.13",
  "author": "Arnon001 <support@arnon.games>",
  "description": "Application for ekoloko",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/ekolokonet/ekoloko-desktop-app.git"
  },
  "scripts": {
    "dev": "node scripts/withLegacyOpenSSL.js electron-webpack dev",
    "compile": "node scripts/withLegacyOpenSSL.js electron-webpack",
    "build": "npm run compile && electron-builder",
    "dist": "npm run compile && electron-builder",
    "dist:dir": "npm run dist -- --dir -c.compression=store -c.mac.identity=null",
    "dist:linux": "npm run compile && electron-builder -l",
    "mac": "npm run compile && electron-builder --mac zip --x64 -c.mac.identity=null",
    "dist:mac": "npm run compile && electron-builder --mac zip --x64 -c.mac.identity=null",
    "dist:mac:dmg": "npm run dist:mac && node scripts/createMacDmg.js",
    "dist:mac:dir": "npm run compile && electron-builder --mac --x64 --dir -c.compression=store -c.mac.identity=null",
    "dist:mac:universal": "npm run compile && electron-builder --mac --universal"
  },
  "dependencies": {
    "electron-updater": "4.3.9",
    "source-map-support": "^0.5.16"
  },
  "devDependencies": {
    "electron": "8.2.0",
    "electron-builder": "^22.4.1",
    "electron-webpack": "^2.8.2",
    "webpack": "~4.42.1"
  },
  "build": {
    "appId": "org.ekoloko",
    "productName": "ekoloko",
    "compression": "maximum",
    "asar": true,
    "afterPack": "./scripts/afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "ekolokonet",
        "repo": "ekoloko-desktop-app"
      }
    ],
    "extraResources": [
      "./assets/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "extraResources": [
        "./plugins/x64/**",
        "./plugins/x64-debug/**"
      ],
      "certificateFile": "${env.WIN_CSC_LINK}",
      "certificatePassword": "${env.WIN_CSC_KEY_PASSWORD}",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "rfc3161TimeStampServer": "http://timestamp.digicert.com"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game",
      "icon": "build/icon.png",
      "extraResources": [
        "./assets/**",
        "./plugins/linux/**"
      ]
    },
    "mac": {
      "target": [
        "zip"
      ],
      "extraResources": [
        "./plugins/mac/**"
      ],
      "icon": "build/icon.icns",
      "identity": "${env.APPLE_IDENTITY}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "include": "build/installer.nsh",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": true
    }
  }
}
